# Original PKGBUILD from https://aur.archlinux.org/cgit/aur.git/tree/PKGBUILD?h=netease-cloud-music

# Maintainer: kXuan <kxuanobj at gmail dot com>
# Contribuor: Peter Cai <peter at typeblog dot net>

pkgname=netease-cloud-music-portable
pkgver=1.2.1
pkgrel=10
pkgdesc="Netease Cloud Music, sandboxed by Portable."
arch=("x86_64")
url="https://music.163.com"
provides=(netease-cloud-music)
conflicts=(netease-cloud-music)
license=('custom')
makedepends=(portable-packer)
source=(
	"config.toml"
        "desktop.file"
        inner.sh
)
sha256sums=('d93ba536660df02d02489de9c91034e81297e7eea1bcf270270bad39c19f21c8'
            'bda645b64e77a99297fc5f2777f72e3f1c71302699c4c77b9748eda1af3218d0'
            'a9d4a83f6c9e8bcbe50dec3e3546884201619ec96efa5c4977afde3291ac206d')


package() {
	depends=('gtk2' 'gtk3' 'libvlc' 'taglib1' "vlc")
	depends+=(portable)
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy netease-cloud-music \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
	install -vDm755 "${srcdir}/inner.sh" "${pkgdir}/usr/lib/portable/overlay-usr/netease-cloud-music"
	ln -sf "/usr/share/applications/com.netease.CloudMusic.desktop" "${pkgdir}/usr/share/applications/netease-cloud-music.desktop"
}

