package() {
  declare -x -g pkgdir
  declare -x -g pkgname
  declare -x -g srcdir
  portable-packer \
    -v \
    --distro arch \
    --mode copy qqmusic-bin \
    --hash true \
    --config "${srcdir}/portable-config" \
    --desktop-file "${srcdir}/com.qq.QQmusic.desktop"
}
