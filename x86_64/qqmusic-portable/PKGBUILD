pkgname=qqmusic-portable
_pkgname=qqmusic
pkgver=1.1.8
pkgrel=1
pkgdesc="腾讯QQ音乐"
arch=("x86_64")
url="https://y.qq.com/"
license=("CC0-1.0")
depends=('nss' 'libxss' 'gtk3' 'alsa-lib' 'portable')
makedepends=("qqmusic")
provides=("$_pkgname")
conflicts=("$_pkgname")
source=(
  "com.qq.QQmusic.desktop"
  "portable-config"
)
sha512sums=(
  'e2a1ebc3d03433b9c500da8b234f2f2a1bc6dba3cd296d246a442953036fe90ddabe67abef393dd52d269c1775296948c125e1c15734d6b276d1dab7261a3d18'
  'ce932ddd08f7cb36c602b36eae1025a12cdc4bccc36d0548988fe547af8aa186b29caf2c6ab309aa71144fb765c61bec0776336cb7700cd7c5369501cd9d9611')

package() {
  declare -x -g pkgdir
  declare -x -g pkgname
  declare -x -g srcdir
  portable-packer \
    -v \
    --distro arch \
    --mode copy qqmusic-bin \
    --hash true \
    --config "${srcdir}/portable-config" \
    --desktop-file "${srcdir}/com.qq.QQmusic.desktop"
}
