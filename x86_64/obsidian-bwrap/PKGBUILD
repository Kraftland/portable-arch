# Contributor: Xuanwo <xuanwo@archlinuxcn.org>

pkgname=obsidian-bwrap
pkgver=1.12.7
pkgrel=1
pkgdesc="A powerful knowledge base that works on top of a local folder of plain text Markdown files. Sandboxed by portable for privacy."
arch=('x86_64')
url="https://obsidian.md"
license=('custom:Commercial')
makedepends+=(portable-packer obsidian)
options=(!strip !debug)
source=(
	"config.toml"
        "obsidian.desktop"
)
sha256sums=('b7bbb8548102c76d4c79842c9323243df190e74f5c2a612a8afb91673f26af74'
            'e42c6a07f5fe11cbf917850050b579979c101727f2d995034df23cc3538f49d1')

package() {
	cd "$srcdir"
	depends+=('zlib' 'hicolor-icon-theme' 'fuse' 'electron' 'portable')

	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy obsidian \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/obsidian.desktop"
}
