pkgname=obsidian-bwrap
pkgver=1.12.7
pkgrel=1
pkgdesc="A powerful knowledge base that works on top of a local folder of plain text Markdown files. Sandboxed by portable for privacy."
arch=('x86_64')
url="https://obsidian.md"
license=('custom:Commercial')
makedepends+=(portable-packer obsidian)
options=(!strip !debug)
source=("obsidian.sh"
	"config.toml"
        "obsidian.desktop"
)
sha256sums=('2c43aa33e989f946c2af48b07c3e7f3683356f91fcefa6d2970ac2531ed197a1'
            '3ea41ad31981798a701db564a82ea16c1bf1490a8fe060c0fbea249913435288'
            '5d12051d82261ab2a9523879abfbbd2f853ef9433e2789084b6a70f8b1f6794e'
            'fcbe08b111d9c1fdb09b9c08952b06e1c829c62163eba2584c4b4ec859be079d')

package() {
	cd "$srcdir"
	depends+=('zlib' 'hicolor-icon-theme' 'fuse' 'electron' 'portable')

	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy obsidian \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/obsidian.desktop"
}
