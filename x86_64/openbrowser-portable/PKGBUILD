# Maintainer: Kimiblock Moe

pkgname=openbrowser-portable
pkgver=1.1.1073.0
pkgrel=1
pkgdesc="CERNET browser sandboxed by Portable"
arch=(x86_64)
url="https://scholar.edu.cn/download.html"
license=('LicenseRef-unknown')
makedepends=(tar portable-packer)
source=(
	"https://download.scholar.edu.cn/openbrowser/ubuntu/openbrowser-cn-stable_1.1.1073.0-1_amd64.deb"
	config.toml
	desktop.file
)
sha256sums=('acc48fada9568c89a15ed71b9f7ff5f7c03a98662c7a8039fcb0f65c15036d5d'
            '99ee3bc213089e654157167a30995aec977ecdc5228e7c6db24bf07ef8dbffed'
            '881535bae986298a3d00e117a1474c0920d438db6ed491339ee849dee3eda369')
provides=(openbrowser)
conflicts=(openbrowser)

function package() {
	cd "${srcdir}"
	depends=(portable bash alsa-lib  dbus  desktop-file-utils  gtk3  hicolor-icon-theme  libcups  libffi  libgcrypt libpulse  libva  libxss  nss  pciutils  systemd  ttf-liberation  xdg-utils  fontconfig  brotli libjpeg-turbo  flac  libxml2  libwebp  minizip  opus  harfbuzz  libxslt  freetype2)
	tar -xf data.tar.xz ./opt
	tar -xf data.tar.xz ./usr
	cp -a \
		"${srcdir}/opt" \
		"${pkgdir}"
	declare -x -g pkgdir srcdir pkgname
	portable-packer \
		-v \
		--distro arch \
		--mode post \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
}
