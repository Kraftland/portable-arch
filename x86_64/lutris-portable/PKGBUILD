# Maintainer: sf467

pkgname=lutris-portable
pkgver=0.5.22
pkgrel=1
epoch=1
pkgdesc="Lutris by portable"
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later')
groups=()
provides=(lutris)
options=(!debug !strip)
conflicts=("lutris")

optdepends=()

makedepends+=(lutris portable-packer)

checkdepends=()

source=(
	config.toml
	desktop.file
)

sha256sums=('93773eeac6e1600b551914b15bcbbaa543fb657938bfcca265aae1dc0713478e'
         '785c198258735b74e3a5a1c2c488acbd09ffc34bc943e90c7da57932e21946e4')

function package() {
	depends=("portable"  cabextract  curl  gdk-pixbuf2  glib2  gnome-desktop
                 gobject-introspection-runtime  gtk3  hicolor-icon-theme  mesa-utils
                 p7zip  pango  psmisc  python  python-cairo  python-certifi
                 python-dbus  python-distro  python-evdev  python-gobject
                 python-lxml  python-moddb  python-pillow  python-requests
                 python-urllib3  python-yaml  unzip  webkit2gtk-4.1
                 xdg-desktop-portal-impl  xorg-xrandr)
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
        install -vDm755 /usr/bin/lutris -t "${pkgdir}/usr/lib/portable/overlay-usr"
	portable-packer \
		-v \
		--distro arch \
		--mode copy lutris \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
}
