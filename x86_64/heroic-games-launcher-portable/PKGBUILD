# Maintainer: Kimiblock Moe

pkgname=heroic-games-launcher-portable
pkgver=2.20.1
pkgrel=1
epoch=1
pkgdesc="Heroic sandboxed by portable"
arch=('x86_64')
url="https://github.com/Kraftland/portable"
license=('GPL-3.0-or-later')
groups=()
provides=(heroic-games-launcher)
options=(!debug !strip)
conflicts=("heroic-games-launcher")

optdepends=()

makedepends+=(heroic-games-launcher-bin portable-packer)

checkdepends=()

source=(
	config.toml
	desktop.file
)


md5sums=('edd175309382ef8b40907f6d17218996'
         '754c05650789a7249855ef6620e32ef2')

function package() {
	depends=("portable" fuse2  gawk  python-wheel  python-setuptools)
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy heroic-games-launcher-bin \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
}
