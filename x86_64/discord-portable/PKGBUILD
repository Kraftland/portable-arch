pkgname=discord-portable
_pkgname=Discord
pkgver=0.0.143
pkgrel=1
epoch=1
pkgdesc="All-in-one voice and text chat for gamers. Sandboxed for privacy."
arch=('x86_64')
url='https://discord.com'
license=('custom')
conflicts=("discord")
makedepends+=(portable-packer discord)
provides+=("discord" "discord-sandbox" "discord-portable")
options=(!debug !strip)
replaces+=(discord-bwrap)
source=(
	"config.toml"
	"discord.sh"
	"discord.desktop"
	)
sha512sums=('6297c83603fed711fe3ba6a1156a3cd0db16ef748d888e0b42128e483db6b2b987b4acc76af5657488802c15a01f68269c48879a786b983c3b05a42c67142566'
            '412d788d281267800c9f9fe65ac356b943aeac2c66a12fba50f5a2012387b18626ab3e8dcce915f0f7330998959320b451b0cc88acf8457c8ed74ae9ed674399'
            '5095a6d1115812c335528ea6bff99cb07f75126324f971d85b145fd926e7cb2b6bbf66bc0d6829ecfd2a63e6d001ff8171a0fb75a633763ffbfe1b940e2574f6')

function prepare() {
	echo '''{
  "SKIP_HOST_UPDATE": true
}''' >"${srcdir}/skip-update.json"
}


package() {
	depends+=('libnotify' 'libxss' 'nspr' 'nss' 'gtk3' libpulse libappindicator-gtk3 "portable")
	export pkgdir
	export pkgname
	export srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy discord \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/discord.desktop"

	install -Dm755 discord.sh "${pkgdir}/usr/lib/portable/overlay-usr/discord"
	install -Dm644 "${srcdir}/skip-update.json" "${pkgdir}/usr/share/discord-bwrap/settings.json"
	install -d "${pkgdir}/usr/share/icons/hicolor/256x256/apps"
	ln -sf "/opt/discord/discord.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/discord.png"
}
