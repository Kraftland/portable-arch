# Maintainer: Kimiblock Moe

pkgname=spotify-portable
pkgver='1.2.63.394'
epoch=1
pkgrel=2
pkgdesc='Music streaming service. Sandboxed by portable with Wayland support.'
arch=('x86_64')
license=('custom')
url='https://www.spotify.com'
makedepends=(portable-packer)
optdepends=('ffmpeg4.4: Adds support for playback of local files'
            'libnotify: Desktop notifications')
options=('!strip')

source=(config.toml desktop.file)
sha512sums=('348b553278d5afd00d2c30f3ecb2a783664affc8557d802e0144c3010fc6f27e6eba870f173bfb9b94d0882d56e178a7af09c81c16b86e3d0e81eb924c804daf'
            '24147db4d58407695b38e352d071d95ee4c10243f8e33496abe20f88b9f50d3141991df5838eb848523ab7c8636946d6c6b22a7a02275edc22000a8ea6bb5b56')

package() {
	depends=('alsa-lib>=1.0.14' 'gtk3' 'libxss' 'desktop-file-utils' 'openssl' 'nss' 'at-spi2-atk' 'libcurl-gnutls' 'libsm' 'libayatana-appindicator')
	depends+=(portable)
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy spotify \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
	ln -sf "/usr/share/applications/com.spotify.player.desktop" "${pkgdir}/usr/share/applications/spotify.desktop"
}

