# Maintainer: Kimiblock Moe

pkgname=z-library-bwrap
pkgver=3.1.0
pkgrel=1
pkgdesc="Your gateway to knowledge and culture. Sandboxed by portable and uses system electron"
arch=(x86_64 aarch64)
url="https://go-to-library.sk/"
license=('LicenseRef-unknown')
makedepends=(tar portable-packer)
source=(
	"https://s3proxy-alp.cdn-zlib.sk/swfs_second_public_files/soft/desktop/Z-Library_3.1.0_amd64.deb"
	config.toml
	desktop.file
)
sha256sums=('SKIP'
            'SKIP'
            'SKIP')
provides=(z-library)
conflicts=(z-library)

function package() {
	cd "${srcdir}"
	depends=(electron bash hicolor-icon-theme portable)
	tar -xf data.tar.xz ./opt
	tar -xf data.tar.xz ./usr
	install -Dm644 "${srcdir}/opt/Z-Library/resources/app.asar" \
		"${pkgdir}/usr/lib/z-library-bwrap/app.asar"
	install -d "${pkgdir}/usr/share"
	cp -r "${srcdir}/usr/share/doc" "${srcdir}/usr/share/icons" "${pkgdir}/usr/share"
	declare -x -g pkgdir srcdir pkgname
	portable-packer \
		-v \
		--distro arch \
		--mode post \
		--hash true \
		--config-ng "${srcdir}/config.toml" \
		--desktop-file "${srcdir}/desktop.file"
}
