# Maintainer: sf467

pkgname=musicxx-portable
depends=(gtk3  util-linux-libs  xz)
provides=("musicxx")
conflicts=("musicxx")
pkgver=0.85.7
pkgrel=1
pkgdesc="Audio and video player"
arch=('x86_64')
options=('!debug')
license=('MIT')
url="https://github.com/coolight7/musicxx"
makedepends=(musicxx-bin "portable-packer" "desktop-file-utils")
source=('com.mimicry.musicxx.desktop' 'portable-config')
sha512sums=('7223ce36b27b21dd04b2ca1e3f8db34db883c688725049dbada51b20001fbdaa79bed8e9d94a06a283ed39514c6d92dbfcd633a11356f0016dbf6beafdbaf614'
	'ad2bc9d5ce61f1bed19c0225a20a7f7895ae41b9e907c091a874a11473fe2ceae5c3b193081450ece96e3f1a6072019cee65fe95ee00d8d0425fb05e446edbb9')

package() {
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy musicxx-bin \
		--hash true \
		--config-ng "${srcdir}/portable-config" \
		--desktop-file "${srcdir}/com.mimicry.musicxx.desktop"
}
