# Maintainer: sf467

pkgname=hmcl-portable
pkgver=3.12.4
pkgrel=1
pkgdesc="A Minecraft Launcher which is multi-functional, cross-platform and popular. Sandboxed by portable."
arch=(any)
url="https://hmcl.huangyuhui.net"
license=(Apache)
makedepends=(
	desktop-file-utils
	portable-packer
	hmcl
)
depends=(hicolor-icon-theme)
source=(
        net.huangyuhui.hmcl.desktop
        portable-config)
sha256sums=('744da95283655004d6e231cca886587a9abd3fef47d181b6be3988b21661ad03'
            '4854c2a06dde49a7568bc0d4d88583353356f8f30899a4f960884aedd4585e21')

package() {
	depends+=("portable")
	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy hmcl \
		--hash true \
		--config-ng "${srcdir}/portable-config" \
		--desktop-file "${srcdir}/net.huangyuhui.hmcl.desktop"
}

