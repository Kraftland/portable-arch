pkgname=linuxqq-portable
pkgver=3.2.29_49738
pkgrel=1
epoch=1
pkgdesc="Linux QQ based on Electron, sandboxed by portable"
makedepends+=(desktop-file-utils "linuxqq" "portable-packer")
arch=('x86_64' 'aarch64' 'loong64')
url="https://im.qq.com/linuxqq"
license=('LicenseRef-QQ')
conflicts=("linuxqq")
provides=("linuxqq")
optdepends=('libappindicator-gtk3: Allow QQ to extend a menu via Ayatana indicators in Unity, KDE or Systray (GTK+ 3 library).')
source=("linuxqq.sh" "start.sh" "config.toml" "im.qq.app.desktop")
sha512sums=('5132db083f632c6f4ad7c77f9d3994392c30fac01697f0fec4010cb5daccb33e7d3d56e7a13daaa405a175d0f0e896ae7addc56c9946539389cb4f80bea6ab27'
            '790e03804903a9eaf28e4c3e190c1c474f329ead7a77d741fd44224ef0f5b1f9e479e65b2749399d8d181e53f52d2d0b2e3f9863b3caa3517cd025f6fd16de69'
            '84a6c31dd27378b8f9925de410405ec177b592c8e35cf2f3f470f88f4c83925860a12fc05663750813dc28ef350ad065351f414055a7cde5cc233e25d0326767'
            'ba310fcec0a795391f60348d7bf8379ce3110dcca6d1be7435b9b50cb8271dcedfb16d7607661cf39093f294dde45eab85c84a7436eea9c4adf0743183da4253')
options=('!strip' '!debug')

package() {
  depends+=('nss' 'alsa-lib' 'gtk3' 'at-spi2-core' 'libvips' 'openjpeg2' 'openslide' 'portable')
  declare -x -g pkgdir
  declare -x -g pkgname
  declare -x -g srcdir
  portable-packer \
    -v \
    --distro arch \
    --mode copy linuxqq \
    --hash true \
    --config-ng "${srcdir}/config.toml" \
    --desktop-file "${srcdir}/im.qq.app.desktop"
  install -Dm755 "${srcdir}/linuxqq.sh" "${pkgdir}/usr/lib/portable/info/im.qq.app/start-script.sh"
  install -Dm755 "${srcdir}/start.sh" "${pkgdir}/usr/bin/linuxqq"

}
