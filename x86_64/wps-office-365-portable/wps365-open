#!/bin/bash

# 配置：指定四个外部程序分别打开四种文件类型
WPS_PROGRAM="/host/opt/kingsoft/wps-office/office6/wps"        # WPS Office 打开 Word 文件
EXCEL_PROGRAM="/host/opt/kingsoft/wps-office/office6/et"      # WPS Office 打开 Excel 文件
PPT_PROGRAM="/host/opt/kingsoft/wps-office/office6/wpp"        # WPS Office 打开 PPT 文件
PDF_PROGRAM="/host/opt/kingsoft/wps-office/office6/wpspdf"            # PDF 打开程序

# 如果没有传入文件，则启动默认程序
if [ $# -eq 0 ]; then
    echo "No file specified, opening default program for Word documents..."
    $WPS_PROGRAM &
    wait
    exit 0
fi

# 遍历传入的所有文件
for FILE in "$@"; do
    if [ ! -f "$FILE" ]; then
        echo "File '$FILE' not found!"
        continue
    fi

    # 获取文件的 MIME 类型
    MIME_TYPE=$(file --mime-type -b "$FILE")

    # 根据 MIME 类型选择外部程序
    case "$MIME_TYPE" in
        "application/wps-office.wps" | "application/wps-office.wpt" | "application/wps-office.wpso" | "application/wps-office.wpss" | \
        "application/wps-office.doc" | "application/wps-office.dot" | "application/vnd.ms-word" | "application/msword" | \
        "application/x-msword" | "application/msword-template" | "application/wps-office.docx" | "application/wps-office.dotx" | \
        "application/rtf" | "application/vnd.ms-word.document.macroEnabled.12" | "application/vnd.openxmlformats-officedocument.wordprocessingml.document" | \
        "x-scheme-handler/ksoqing" | "x-scheme-handler/ksowps" | "x-scheme-handler/ksowpp" | "x-scheme-handler/ksoet" | \
        "x-scheme-handler/ksowpscloudsvr" | "x-scheme-handler/ksowebstartupwps" | "x-scheme-handler/ksowebstartupet" | \
        "x-scheme-handler/ksowebstartupwpp" | "application/wps-office.uot3" | "application/wps-office.uott3" | \
        "x-scheme-handler/ksodoccenter")
            echo "Opening Word document with WPS: $FILE"
            $WPS_PROGRAM "$FILE" &
            ;;
        
        "application/wps-office.et" | "application/wps-office.ett" | "application/wps-office.ets" | "application/wps-office.eto" | \
        "application/wps-office.xls" | "application/wps-office.xlt" | "application/vnd.ms-excel" | "application/msexcel" | \
        "application/x-msexcel" | "application/wps-office.xlsx" | "application/wps-office.xltx" | \
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" | "application/wps-office.uos" | \
        "application/wps-office.uos3" | "application/wps-office.uost3")
            echo "Opening Excel file with WPS: $FILE"
            $EXCEL_PROGRAM "$FILE" &
            ;;
        
        "application/wps-office.dps" | "application/wps-office.dpt" | "application/wps-office.dpss" | "application/wps-office.dpso" | \
        "application/wps-office.ppt" | "application/wps-office.pot" | "application/vnd.ms-powerpoint" | \
        "application/vnd.mspowerpoint" | "application/mspowerpoint" | "application/powerpoint" | \
        "application/x-mspowerpoint" | "application/wps-office.pptx" | "application/wps-office.potx" | \
        "application/vnd.openxmlformats-officedocument.presentationml.presentation" | \
        "application/vnd.openxmlformats-officedocument.presentationml.slideshow" | "application/wps-office.uop" | \
        "application/wps-office.uop3" | "application/wps-office.uopt3")
            echo "Opening PowerPoint file with WPS: $FILE"
            $PPT_PROGRAM "$FILE" &
            ;;
        
        "application/pdf")
            echo "Opening PDF file with Evince: $FILE"
            $PDF_PROGRAM "$FILE" &
            ;;
        
        *)
            # 对于未知文件类型，使用默认的 WPS 打开程序
            echo "Unknown file type: $MIME_TYPE. Opening with default program: WPS."
            $WPS_PROGRAM "$FILE" &
            ;;
    esac
done

# 等待所有后台进程完成
wait
