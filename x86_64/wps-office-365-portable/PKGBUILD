# Maintainer: sf467

pkgbase=wps-office-365-portable
pkgname=wps-office-365-portable
pkgver=12.1.2.24730.portable
pkgrel=2
pkgdesc="Kingsoft Office (WPS Office) CN version - an office productivity suite"
makedepends+=(desktop-file-utils "wps-office-365" "portable")
depends=(
  'fontconfig' 'libxrender' 'xdg-utils' 'glu' 'coreutils'
  'libpulse' 'libxss' 'sqlite' 'libtool' 'libtiff'
  'libxslt' 'libjpeg-turbo' 'libpng' 'freetype2')

arch=('x86_64')
license=('LicenseRef-WPS-EULA')
url="https://365.wps.cn/"
options=('!emptydirs' '!debug')
replaces+=(wps-office-cn-bwrap)
conflicts=('kingsoft-office' 'wps-office' "wps-office-365" wps-office-cn-bwrap)
provides=('kingsoft-office' 'wps-office' "wps-office-365" wps-office-cn-bwrap)

source=(portable-config wps365-open cn.wps.wps_365.desktop wps)
sha1sums=('1e70271ac573ed609e9451c6bbd77fd811e71fa7'
          '0cb27cb3a49735bab9314896980679a4b0eca54e'
          '9b1b7676f54dd9f7419a7c72275cdef8adb1c754'
	  'c247299f2c66a3b3e59efcf74fa41733f65c8e38')

package() {
	depends+=('fontconfig' 'xorg-mkfontscale' 'libxrender' 'desktop-file-utils' 'shared-mime-info' 'xdg-utils' 'glu' 'sdl2' 'libpulse' 'hicolor-icon-theme' 'libxss' 'sqlite' 'libtool' 'libxslt' 'libjpeg-turbo')
    optdepends=('cups: Printing support'
                'libjpeg-turbo: JPEG image codec support'
                'pango: for complex (right-to-left) text support'
                'curl: An URL retrieval utility and library'
                'ttf-wps-fonts: Symbol fonts required by wps-office'
                'ttf-ms-fonts: Microsft Fonts recommended for wps-office'
                'wps-office-fonts: FZ TTF fonts provided by wps community'
                'wps-office-mui-zh-cn: zh_CN support for WPS Office')

	declare -x -g pkgdir
	declare -x -g pkgname
	declare -x -g srcdir
	portable-packer \
		-v \
		--distro arch \
		--mode copy wps-office-365 \
		--hash true \
		--config "${srcdir}/portable-config" \
		--desktop-file "${srcdir}/cn.wps.wps_365.desktop"
	rm "${pkgdir}/usr/share/mime/packages/custom-wps-office.xml"
	install -vDm755 "${srcdir}/wps365-open" "${pkgdir}/usr/lib/portable/info/cn.wps.wps_365/wps365-open"
	install -vDm755 "${srcdir}/wps" "${pkgdir}/usr/bin/wps"
}
